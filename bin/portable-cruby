#!/usr/bin/env bash
#
# portable-cruby - Package Ruby apps into single portable binaries.
#
# Usage:
#   portable-cruby pack --gem herb [--target aarch64-darwin]
#   portable-cruby pack --gemfile Gemfile --entry my_app [--target aarch64-linux]
#   portable-cruby build-ruby [--target aarch64-linux]
#   portable-cruby clean
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

RUBY_VERSION="${PORTABLE_CRUBY_RUBY_VERSION:-4.0.0}"

# Auto-detect host target
HOST_ARCH=$(uname -m | sed 's/arm64/aarch64/' | sed 's/amd64/x86_64/')
HOST_OS=$(uname -s | tr '[:upper:]' '[:lower:]')
HOST_TARGET="${HOST_ARCH}-${HOST_OS}"

usage() {
    cat <<'EOF'
portable-cruby - Package Ruby apps into single portable binaries.

Commands:
  pack          Package a gem or Gemfile-based app into a single binary
  build-ruby    Build the static Ruby interpreter for a target
  clean         Remove all build artifacts

Pack options:
  --gem NAME        Package a rubygems gem (installs it automatically)
  --gemfile PATH    Package a Gemfile-based app
  --entry BIN       Entry point binary name (defaults to gem name)
  --target TARGET   Target platform (default: current host)
  --output PATH     Output binary path (default: build/<name>)
  --prune LEVEL     Pruning level: none, default (default: default)
  --keep-gems LIST  Comma-separated gems to keep despite prune list

Targets:
  aarch64-darwin    macOS Apple Silicon
  x86_64-darwin     macOS Intel
  aarch64-linux     Linux ARM64
  x86_64-linux      Linux x86_64

Environment:
  PORTABLE_CRUBY_RUBY_VERSION  Ruby version to build (default: 4.0.0)

Examples:
  portable-cruby pack --gem herb
  portable-cruby pack --gem rails --entry rails --target aarch64-linux
  portable-cruby pack --gemfile ./Gemfile --entry my_app
EOF
}

cmd_build_ruby() {
    local target="${1:-$HOST_TARGET}"
    "${PROJECT_DIR}/scripts/build-ruby.sh" \
        --ruby-version "$RUBY_VERSION" \
        --target "$target" \
        --output "build/ruby-${RUBY_VERSION}-${target}"
}

cmd_pack() {
    local gem=""
    local gemfile=""
    local entry=""
    local target="$HOST_TARGET"
    local output=""
    local prune="default"
    local keep_gems=""
    local extra_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --gem)       gem="$2"; shift 2 ;;
            --gemfile)   gemfile="$2"; shift 2 ;;
            --entry)     entry="$2"; shift 2 ;;
            --target)    target="$2"; shift 2 ;;
            --output)    output="$2"; shift 2 ;;
            --prune)     prune="$2"; shift 2 ;;
            --keep-gems) keep_gems="$2"; shift 2 ;;
            *)           echo "Unknown pack option: $1"; exit 1 ;;
        esac
    done

    if [[ -z "$gem" && -z "$gemfile" ]]; then
        echo "ERROR: Must specify --gem or --gemfile"
        echo "Run: portable-cruby pack --help"
        exit 1
    fi

    local ruby_dir="build/ruby-${RUBY_VERSION}-${target}"
    local stub="build/stub"

    # Determine output name
    if [[ -z "$output" ]]; then
        local name="${gem:-$(basename "${gemfile%/Gemfile}")}"
        [[ -n "$entry" ]] && name="$entry"
        output="build/${name}"
        # Add target suffix for non-host builds
        [[ "$target" != "$HOST_TARGET" ]] && output="${output}-${target}"
    fi

    # Determine correct stub
    local target_os="${target#*-}"
    if [[ "$target_os" == "linux" && "$HOST_OS" != "linux" ]]; then
        stub="build/stub-linux"
    fi

    # Step 1: Build Ruby if needed
    if [[ ! -f "${ruby_dir}/bin/ruby" ]]; then
        echo "==> Building Ruby ${RUBY_VERSION} for ${target}..."
        cmd_build_ruby "$target"
    fi

    # Step 2: Build stub if needed
    if [[ ! -f "$stub" ]]; then
        echo "==> Compiling stub..."
        if [[ "$target_os" == "linux" && "$HOST_OS" != "linux" ]]; then
            make -C "$PROJECT_DIR" stub-linux
        else
            make -C "$PROJECT_DIR" stub
        fi
    fi

    # Step 3: Install gem if in gem mode
    if [[ -n "$gem" ]]; then
        # Check if already installed
        local gem_found=$(find "${ruby_dir}/lib/ruby/gems" -maxdepth 3 -type d -name "${gem}-*" 2>/dev/null | head -1)
        if [[ -z "$gem_found" ]]; then
            echo "==> Installing gem '${gem}'..."
            if "${ruby_dir}/bin/ruby" --version >/dev/null 2>&1; then
                "${ruby_dir}/bin/gem" install "$gem" --no-document
            else
                echo "    Cross-platform: installing via Docker..."
                docker run --rm -v "$(pwd)/${ruby_dir}:/opt/ruby" alpine:3.21 \
                    sh -c "apk add --no-cache build-base libgcc >/dev/null 2>&1 && \
                           /opt/ruby/bin/gem install $gem --no-document"
            fi
        fi
    fi

    # Step 4: Package
    local pack_args=(
        --ruby-dir "$ruby_dir"
        --stub "$stub"
        --output "$output"
        --prune "$prune"
    )

    if [[ -n "$gem" ]]; then
        pack_args+=(--gem "$gem")
        [[ -n "$entry" ]] && pack_args+=(--entry "$entry")
    else
        pack_args+=(--gemfile "$gemfile")
        pack_args+=(--entry "${entry:-$(basename "$gemfile" | sed 's/Gemfile/app/')}")
    fi

    [[ -n "$keep_gems" ]] && pack_args+=(--keep-gems "$keep_gems")

    "${PROJECT_DIR}/scripts/package.sh" "${pack_args[@]}"
}

cmd_clean() {
    echo "==> Cleaning build artifacts..."
    rm -rf "${PROJECT_DIR}/build/"
    echo "    Done."
}

# Main dispatch
case "${1:-}" in
    pack)     shift; cmd_pack "$@" ;;
    build-ruby)
        shift
        target="${1:-$HOST_TARGET}"
        cmd_build_ruby "$target"
        ;;
    clean)    cmd_clean ;;
    -h|--help|help|"")  usage ;;
    *)
        echo "Unknown command: $1"
        echo "Run: portable-cruby --help"
        exit 1
        ;;
esac
